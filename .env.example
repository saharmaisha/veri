# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
NEXT_PUBLIC_FEEDBACK_FORM_URL=
NEXT_PUBLIC_SUPPORT_EMAIL=
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# OpenAI
OPENAI_API_KEY=sk-your-openai-key

# Pinterest OAuth
PINTEREST_CLIENT_ID=your-pinterest-client-id
PINTEREST_CLIENT_SECRET=your-pinterest-client-secret
PINTEREST_REDIRECT_URI=http://localhost:3000/api/pinterest/callback

# Google Sheets (OAuth — preferred)
# Create credentials at: console.cloud.google.com → APIs & Services → Credentials → Create Client (Web application)
# Set redirect URI to: http://localhost:3000/api/google/callback
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/callback
GOOGLE_SHEETS_DEFAULT_RANGE=Sheet1!A:P

# Legacy service account (only if you cannot use OAuth)
GOOGLE_CLIENT_EMAIL=
GOOGLE_PRIVATE_KEY=

# Shopping Providers
# Options: mock | text | image | full
SHOPPING_PROVIDER_MODE=mock
TEXT_SHOPPING_PROVIDER_KEY=
IMAGE_SHOPPING_PROVIDER_KEY=

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_SECRET=your-64-char-hex-encryption-secret
